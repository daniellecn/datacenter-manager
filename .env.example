# ─── Database ────────────────────────────────────────────────────────────────
# The app connects as the restricted role (dcm_app), not the superuser.
# Migrations are run separately using the superuser credentials.
DATABASE_URL=postgresql+asyncpg://dcm_app:change_me@postgres:5432/datacenter
# Superuser URL used by Alembic migrations (needs CREATE/DROP TABLE privileges)
MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:change_me@postgres:5432/datacenter

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=datacenter

# Restricted application role — created by postgres/init.sh on first startup
DCM_DB_USER=dcm_app
DCM_DB_PASSWORD=change_me

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── TLS (production) ─────────────────────────────────────────────────────────
# Place your cert and key in nginx/certs/ before starting in production.
# To generate a self-signed cert for testing:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout nginx/certs/server.key -out nginx/certs/server.crt \
#     -subj "/CN=datacenter-manager"
TLS_CERT_PATH=/etc/nginx/certs/server.crt
TLS_KEY_PATH=/etc/nginx/certs/server.key

# ─── App ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]
ENVIRONMENT=development
# Use WARNING in production. Set to INFO or DEBUG only for troubleshooting.
LOG_LEVEL=WARNING

# ─── Retention ────────────────────────────────────────────────────────────────
POWER_READINGS_RETENTION_DAYS=90

# ─── Initial admin user (created on first startup if no users exist) ──────────
INITIAL_ADMIN_USERNAME=admin
# Temporary bootstrap password — app forces a password change on first login.
INITIAL_ADMIN_PASSWORD=
